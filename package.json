{
  "name": "hyperpipe-tui",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://hyperpipe.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/squip/hyperpipe.git",
    "directory": "hyperpipe-tui"
  },
  "bin": {
    "hyperpipe-tui": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup src/cli.tsx --format esm --out-dir dist --clean && node scripts/add-shebang.cjs dist/cli.js",
    "bundle:release": "node ./scripts/bundle-release.mjs",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e",
    "demo:e2e": "tsx test/e2e/interactive-demo.tsx",
    "demo:e2e:stay-open": "tsx test/e2e/interactive-demo.tsx --stay-open",
    "demo:e2e:real": "tsx test/e2e/interactive-demo-real.tsx",
    "demo:e2e:real:stay-open": "tsx test/e2e/interactive-demo-real.tsx --stay-open",
    "demo:e2e:real:matrix": "tsx test/e2e/live-workflow-matrix-real.tsx",
    "demo:e2e:real:two-user": "tsx test/e2e/live-two-user-workflows-real.tsx",
    "demo:e2e:real:direct-join-host-online": "tsx test/e2e/direct-join-host-online-debug-real.tsx",
    "demo:e2e:real:closed-gateway-inheritance-docker": "tsx test/e2e/closed-gateway-inheritance-docker-real.tsx",
    "demo:e2e:real:relay-scoped-phased-docker": "tsx test/e2e/relay-scoped-phased-docker.tsx",
    "pack:check": "npm pack --dry-run"
  },
  "files": [
    "dist/**",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@squip/hyperpipe-bridge": "^0.1.0",
    "@squip/hyperpipe-core": "^0.1.0",
    "@squip/hyperpipe-core-host": "^0.1.0",
    "chalk": "^5.6.2",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "nostr-tools": "^2.20.0",
    "react": "^18.3.1",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/ws": "^8.18.1",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
